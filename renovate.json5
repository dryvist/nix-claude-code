{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended", "local>dryvist/.github"],
  // Keep flake inputs — including the plugin marketplace inputs surfaced to
  // consumers (jacobpevans-cc-plugins et al.) — current. Without this the lock
  // freezes and downstreams (nix-ai) inherit stale plugin/skill content.
  nix: {
    enabled: true,
  },
}
